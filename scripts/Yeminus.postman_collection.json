{
  "info": {
    "name": "Yeminus Service Management API",
    "description": "Complete API collection for Yeminus Service Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "  pm.test('Login successful', () => pm.expect(body.success).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"admin\", \"password\": \"Admin123!\"}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Get All Clients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/clients"
          }
        },
        {
          "name": "Get Client By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/clients/{{clientId}}"
          }
        },
        {
          "name": "Create Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('clientId', body.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/clients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Client\",\n  \"documentNumber\": \"99999999\",\n  \"phone\": \"+57300000099\",\n  \"email\": \"test.client@email.com\",\n  \"address\": \"Test Address 123\"\n}"
            }
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/clients/{{clientId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Client\",\n  \"documentNumber\": \"99999999\",\n  \"phone\": \"+57300000099\",\n  \"email\": \"updated.client@email.com\",\n  \"address\": \"Updated Address 456\"\n}"
            }
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/clients/{{clientId}}"
          }
        }
      ]
    },
    {
      "name": "Technicians",
      "item": [
        {
          "name": "Get All Technicians",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/technicians"
          }
        },
        {
          "name": "Create Technician",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('technicianId', body.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/technicians",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Technician\",\n  \"documentNumber\": \"77777777\",\n  \"phone\": \"+57310000077\",\n  \"email\": \"tech@yeminus.com\",\n  \"specialty\": \"Electrical\"\n}"
            }
          }
        },
        {
          "name": "Update Technician",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/technicians/{{technicianId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Technician\",\n  \"documentNumber\": \"77777777\",\n  \"phone\": \"+57310000077\",\n  \"email\": \"tech.updated@yeminus.com\",\n  \"specialty\": \"HVAC\"\n}"
            }
          }
        },
        {
          "name": "Delete Technician",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/technicians/{{technicianId}}"
          }
        }
      ]
    },
    {
      "name": "Service Orders",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get Orders with Filters",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders?status=2&specialty=Electrical",
              "query": [
                { "key": "status", "value": "2" },
                { "key": "specialty", "value": "Electrical" }
              ]
            }
          }
        },
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('orderId', body.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n  \"technicianId\": \"dddddddd-dddd-dddd-dddd-dddddddddddd\",\n  \"description\": \"Full electrical inspection required\"\n}"
            }
          }
        },
        {
          "name": "Change Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": 2}"
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    }
  ]
}
